# NEW nginx site for RepoLens only — does not modify your existing website config.
#
# 1. Copy to the server:
#    sudo cp deploy/nginx/repolens.conf.example /etc/nginx/sites-available/repolens
# 2. Edit server_name and paths if needed
# 3. Enable:
#    sudo ln -s /etc/nginx/sites-available/repolens /etc/nginx/sites-enabled/repolens
# 4. Test and reload:
#    sudo nginx -t && sudo systemctl reload nginx
# 5. SSL (new subdomain only):
#    sudo certbot --nginx -d repolens.YOURDOMAIN.com

server {
    listen 80;
    server_name repolens.YOURDOMAIN.com;

    # Allow ZIP uploads up to 25 MB
    client_max_body_size 26m;

    # RepoLens API (FastAPI on localhost:8010)
    location /api/ {
        proxy_pass http://127.0.0.1:8010/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # BYOK AI headers (never logged by RepoLens backend)
        proxy_set_header X-AI-Provider $http_x_ai_provider;
        proxy_set_header X-AI-Model $http_x_ai_model;
        proxy_set_header X-AI-Api-Key $http_x_ai_api_key;

        proxy_read_timeout 180s;
        proxy_connect_timeout 60s;
        proxy_send_timeout 180s;
    }

    # Health check (optional)
    location /health {
        proxy_pass http://127.0.0.1:8010/health;
        proxy_set_header Host $host;
    }

    # RepoLens frontend (Next.js on localhost:3010)
    location / {
        proxy_pass http://127.0.0.1:3010;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

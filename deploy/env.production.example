# Production .env for docker-compose.prod.yml
# Copy on VPS: cp deploy/env.production.example .env

# Replace with your public URL (same origin — nginx routes /api to backend)
NEXT_PUBLIC_API_URL=https://repolens.YOURDOMAIN.com
CORS_ORIGINS=https://repolens.YOURDOMAIN.com

# Optional server-side AI fallback (BYOK in browser is preferred for public deploy)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
REPORT_PROVIDER=groq

MAX_ANALYSIS_SECONDS=120
REPORT_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
DEBUG=false

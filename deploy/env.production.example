# Production .env for docker-compose.prod.yml
# On VPS: cp deploy/env.production.example /opt/repolens/.env

NEXT_PUBLIC_API_URL=https://rl.anikait.page
CORS_ORIGINS=https://rl.anikait.page

# Optional server-side AI fallback (BYOK in browser is preferred for public deploy)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
REPORT_PROVIDER=groq

MAX_ANALYSIS_SECONDS=120
REPORT_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
DEBUG=false

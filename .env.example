# Environment variables for Docker Compose
# Copy to .env and fill in values

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TOP_FINDINGS_LIMIT=15
MAX_UPLOAD_SIZE=26214400
MAX_EXTRACTED_SIZE=104857600
MAX_EXTRACTED_FILES=5000
MAX_SINGLE_FILE_SIZE=10485760
MAX_ANALYSIS_SECONDS=120
UPLOAD_DIRECTORY=/tmp/repolens/uploads
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEBUG=false

# Duplicate detection
DUPLICATE_DETECTION_ENABLED=true
DUPLICATE_MIN_LINES=5
DUPLICATE_MAX_FUNCTIONS=300
DUPLICATE_MAX_PAIRS=50
DUPLICATE_HIGH_THRESHOLD=0.95
DUPLICATE_MEDIUM_THRESHOLD=0.90
DUPLICATE_POSSIBLE_THRESHOLD=0.85

NEXT_PUBLIC_API_URL=http://localhost:8000
